# ─── Clinic Identity ───────────────────────────────
CLINIC_NAME=My Clinic Name
DOCTOR_NAME=Dr Deepika
CLINIC_SPECIALTY=Gynecologist
CLINIC_ADDRESS=Your clinic address
CLINIC_PHONE=+918595954095
APPOINTMENT_FEE=₹1000 for clinic visit, ₹500 for online consultation
CLINIC_TIMEZONE=Asia/Kolkata

# ─── Booking Hours ─────────────────────────────────
# Single continuous window: 9 AM to 9 PM
SLOT_DURATION_MINUTES=20
MORNING_START=09:00
MORNING_END=21:00
EVENING_START=09:00
EVENING_END=21:00
WORKING_DAYS=Mon,Tue,Wed,Thu,Fri,Sat

# ─── AI Model ─────────────────────────────────────
OLLAMA_MODEL=gemma4:e4b
OLLAMA_HOST=http://localhost:11434

# ─── Voice Replies ─────────────────────────────────
# TTS providers: auto | chatterbox | qwen3 | piper
# "auto" routes Hindi→Chatterbox, English→Qwen3
TTS_PROVIDER=auto
SEND_AUDIO_REPLIES_FOR_TEXT=true
AUDIO_CACHE_DIR=./audio_cache
PIPER_BINARY=piper
PIPER_VOICE=./voices/en_IN-female-medium.onnx
QWEN3_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base

# ─── Security ──────────────────────────────────────
# Set API_KEY to protect admin endpoints (leave empty to disable)
API_KEY=

# ─── Services ──────────────────────────────────────
WHATSAPP_BOT_URL=http://localhost:3001
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# ─── Data & Exports ───────────────────────────────
EXPORT_DIR=./exports
GOOGLE_SHEET_ID=
GOOGLE_SHEET_GID=
GOOGLE_SERVICE_ACCOUNT_JSON=
# Google Drive folder for patient documents (ID cards, payments, prescriptions, reports)
GOOGLE_DRIVE_FOLDER_ID=1jZvG4cxj2jzx27-lCNsRhJbT4bzZyx8W
GOOGLE_CALENDAR_ID=primary
