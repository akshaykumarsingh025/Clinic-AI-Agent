# ─── Clinic Identity ───────────────────────────────
CLINIC_NAME=My Clinic Name
DOCTOR_NAME=Dr. Full Name
CLINIC_SPECIALTY=Gynecologist
CLINIC_ADDRESS=Your clinic address
CLINIC_PHONE=+91XXXXXXXXXX
APPOINTMENT_FEE=500
CLINIC_TIMEZONE=Asia/Kolkata

# ─── Booking Hours ─────────────────────────────────
# Single continuous window: 9 AM to 9 PM
SLOT_DURATION_MINUTES=20
MORNING_START=09:00
MORNING_END=21:00
EVENING_START=09:00
EVENING_END=21:00
WORKING_DAYS=Mon,Tue,Wed,Thu,Fri,Sat

# ─── AI Model ─────────────────────────────────────
OLLAMA_MODEL=gemma4:e4b
OLLAMA_HOST=http://localhost:11434

# ─── Voice Replies ─────────────────────────────────
PIPER_BINARY=piper
PIPER_VOICE=./voices/en_IN-female-medium.onnx
AUDIO_CACHE_DIR=./audio_cache
SEND_AUDIO_REPLIES_FOR_TEXT=false
TTS_PROVIDER=piper

# VoiceClone (optional — set TTS_PROVIDER=voiceclone to use)
VOICECLONE_PROJECT_DIR=
VOICECLONE_PYTHON=
VOICECLONE_VOICE_SAMPLE=
VOICECLONE_LANGUAGE=auto
VOICECLONE_REF_TEXT=

# ─── Services ──────────────────────────────────────
WHATSAPP_BOT_URL=http://localhost:3001
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# ─── Data & Exports ───────────────────────────────
EXPORT_DIR=./exports
GOOGLE_SHEET_URL=
GOOGLE_SERVICE_ACCOUNT_JSON=
